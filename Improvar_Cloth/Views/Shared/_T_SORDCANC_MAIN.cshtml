@model Improvar.ViewModels.OrderCancelEntry
<script type="text/javascript">
    $(document).ready(function () {
        if ("@Model.DefaultAction" == "V" || "@Model.DefaultAction" == "D") {
            modeView();
        }
        else if ("@Model.DefaultAction" == "A") {
            $('form :input:enabled:visible:not([readonly]):first').focus();
        }
        resizableTables[resizableTables.length] = new ColumnResize(document.getElementById('_T_SORDCANC_MAIN_GRID'));
        $("td").on("mouseover", function (e) { var titlee = $(this).find("input").val(); $(this).attr('title', titlee); });
    });
</script>
<div>
    <div class="table-responsive">
        @if (Model.DefaultView == true)
        {
            @Html.ValidationSummary(true)
            <div class="grid_title">
                @*<img src="~/Image/Minus.png" id="btnDeleteMain" class="Help_image_buttonAddRemove" title="Delete Row" onclick="DeleteRow()" />*@
                <div class="col-md-8">
                    <input type="text" id="search" name="search" class="grid_title_box textbox_image" value="" placeholder="Filter" onkeyup="filterTable(event, '_T_SORDCANC_MAIN_GRID');" />
                    <img src="~/Image/search.png" title="Help" />
                </div>
                <center style="font-size: 11px;color: darkmagenta; border: 1px inset;"><b>@ViewBag.GridHeader Part / Full Item Details</b></center>
            </div>
            <div class="sticky-table sticky-ltr-cells">
                <div style="height:auto;overflow-y:scroll;max-height:265px;">
                    <table id="_T_SORDCANC_MAIN_GRID" class="resizable table-striped" cellpadding="0px" cellspacing="0px" style="width:1550px;">
                        <thead>
                            <tr class="sticky-header" style="height:30px;">
                                <th class="" style="width: 27px;"></th>
                                <th class="" style="width: 40px;text-align:center;">SL No.</th>
                                <th class="" style="width: 130px;">Item Code</th>
                                <th class="" style="width: 470px;">Item Name</th>
                                <th class="" style="width: 130px;">Design</th>
                                <th class="" style="width: 70px;">UOM</th>
                                @if (Model.M_SYSCNFG.MNTNCOLOR == "Y")
                                {
                                    <th class="" style="width: 81px;">Color Code</th>
                                    <th class="" style="width:100px;">Color Name</th>
                                }@if (Model.M_SYSCNFG.MNTNSIZE == "Y")
                                {
                                    <th class="" style="width:107px;">Size</th>
                                }
                                @if (Model.M_SYSCNFG.MNTNPART == "Y")
                                {
                                    <th class="" style="width:100px;">Part</th>
                                }
                                <th class="" style="width: 100px;text-align:right;">Bal. Qnty</th>
                                <th class="" style="width: 100px;text-align:right;">Cancel Qnty</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TSORDDTL_CANC != null)
                            {
                                for (int i = 0; i <= Model.TSORDDTL_CANC.Count - 1; i++)
                                {
                                    <tr style="font-size:12px; font-weight:bold;">
                                        <td class="" style="padding-left:7px;padding-right:7px;">
                                            @Html.CheckBoxFor(model => model.TSORDDTL_CANC[i].Checked, new { id = "chkid" })
                                            @Html.HiddenFor(model => model.TSORDDTL_CANC[i].ORDAUTONO, new { id = "ORDAUTONO_" + i, Value = @Model.TSORDDTL_CANC[i].ORDAUTONO })
                                            @Html.HiddenFor(model => model.TSORDDTL_CANC[i].ORDSLNO, new { id = "ORDSLNO_" + i, Value = @Model.TSORDDTL_CANC[i].ORDSLNO })


                                        </td>
                                        <td class="">
                                            @Html.TextBoxFor(model => Model.TSORDDTL_CANC[i].SLNO, new { id = "SLNO_" + i, @class = " atextBoxFor ", @style = "text-align:center;", maxlength = 2, @TabIndex = -1, @readonly = "readonly" })
                                        </td>
                                        <td class="">
                                            @Html.TextBoxFor(model => Model.TSORDDTL_CANC[i].ITCD, new { id = "ITCD_" + i, @class = " atextBoxFor ", maxlength = 12, @readonly = "readonly" })
                                        </td>
                                        <td class="">
                                            @Html.TextBoxFor(model => model.TSORDDTL_CANC[i].ITNM, new { id = "ITNM_" + i, @class = " atextBoxFor ", maxlength = 60, @TabIndex = -1, @readonly = "readonly" })
                                        </td>
                                        <td class="">
                                            @Html.TextBoxFor(model => model.TSORDDTL_CANC[i].ARTNO, new { id = "ARTNO_" + i, @class = " atextBoxFor ", maxlength = 60, @TabIndex = -1, @readonly = "readonly" })
                                        </td>
                                        <td class="">
                                            @Html.TextBoxFor(model => Model.TSORDDTL_CANC[i].UOM, new { id = "UOM_" + i, @class = " atextBoxFor", @TabIndex = -1, @readonly = "readonly" })
                                        </td>
                                        @if (Model.M_SYSCNFG.MNTNCOLOR == "Y")
                                        {
                                            <td class="">
                                                @Html.TextBoxFor(model => Model.TSORDDTL_CANC[i].COLRCD, new { id = "COLRCD_" + i, @class = " atextBoxFor ", @TabIndex = -1, @readonly = "readonly" })
                                            </td>
                                            <td class="">
                                                @Html.TextBoxFor(model => Model.TSORDDTL_CANC[i].COLRNM, new { id = "COLRNM_" + i, @class = " atextBoxFor ", @TabIndex = -1, @readonly = "readonly", onkeydown = "RepeatAboveRow_TPROGBOM('" + i + "'); " })
                                            </td>
                                        }
                                        @if (Model.M_SYSCNFG.MNTNSIZE == "Y")
                                        {
                                            <td class="">
                                                @Html.TextBoxFor(model => Model.TSORDDTL_CANC[i].SIZECD, new { id = "SIZECD_" + i, @class = " atextBoxFor ", @TabIndex = -1, @readonly = "readonly" })
                                                @Html.HiddenFor(model => model.TSORDDTL_CANC[i].SIZENM, new { id = "SIZENM_" + i })
                                            </td>
                                        }
                                        @if (Model.M_SYSCNFG.MNTNPART == "Y")
                                        {
                                            <td class="">
                                                @Html.TextBoxFor(model => Model.TSORDDTL_CANC[i].PARTCD, new { id = "P_PARTCD_" + i, @class = " atextBoxFor ", @TabIndex = -1, @readonly = "readonly" })
                                                @Html.HiddenFor(model => model.TSORDDTL_CANC[i].PARTNM, new { id = "PARTNM_" + i })
                                            </td>
                                        }
                                        <td class="">
                                            @Html.EditorFor(model => Model.TSORDDTL_CANC[i].QNTY, new { htmlattributes = new { id = "QNTY_" + i, @style = "text-align: right;", @class = " atextBoxFor", maxlength = 12, @readonly = "readonly" } })
                                        </td>
                                        <td class="">
                                            @Html.EditorFor(model => Model.TSORDDTL_CANC[i].CANCQNTY, new { htmlattributes = new { id = "CANCQNTY_" + i, maxlength = 10, @onkeypress = "return numericOnly(this,2);", @class = " atextBoxFor ", @style = "text-align: right;", onblur = "CalculateCancelQnty(this,'" + "QNTY_" + i + "');" } })
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr class="sticky-footer">
                                <td class="sticky-cell" style="width:27px;"> <input type="text" class="atextBoxFor" readonly="readonly" />  </td>
                                <td><input type="text" class="atextBoxFor" readonly="readonly" /></td>
                                <td><input type="text" class="atextBoxFor" readonly="readonly" /></td>
                                <td><input type="text" class="atextBoxFor" readonly="readonly" /></td>
                                <td><input type="text" class="atextBoxFor" readonly="readonly" /></td>
                                <td><input type="text" value="Total:" class="atextBoxFor" style="font-weight:bold;color:red;text-align:right;font-variant:petite-caps;" readonly="readonly" /></td>
                                @if (Model.M_SYSCNFG.MNTNCOLOR == "Y")
                                {
                                    <td><input type="text" class="atextBoxFor" readonly="readonly" /></td>
                                    <td><input type="text" class="atextBoxFor" readonly="readonly" /></td>
                                }
                                @if (Model.M_SYSCNFG.MNTNSIZE == "Y")
                                {
                                    <td><input type="text" class="atextBoxFor" readonly="readonly" /></td>
                                }
                                @if (Model.M_SYSCNFG.MNTNPART == "Y")
                                {
                                    <td style="text-align:right;"></td>
                                }
                                <td style="text-align:right;">
                                    @Html.EditorFor(model => Model.TOTAL_QNTY, new { htmlattributes = new { id = "TOTAL_QNTY", @class = "atextBoxFor", @style = "text-align: right;font-weight:bold;", @onkeypress = "return numericOnly(this,3);", @readonly = "readonly" } })
                                </td>
                                <td style="text-align:right;">
                                    @Html.EditorFor(model => Model.TOTAL_CANCQNTY, new { htmlattributes = new { id = "TOTAL_CANCQNTY", @class = "atextBoxFor", @style = "text-align: right;font-weight:bold;", @onkeypress = "return numericOnly(this,3);", @readonly = "readonly" } })
                                </td>
                            </tr>
                        </tfoot>

                    </table>
                </div>
            </div>
        }
    </div>
</div>
