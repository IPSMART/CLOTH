@model Improvar.ViewModels.ReportViewinHtml
@{
    ViewBag.Title = "Book Print";
    if (Model.MENU_PARA == "SUBLEG") { ViewBag.Title = "Sub Ledger"; }
    if (Model.MENU_PARA == "CASH") { ViewBag.Title = "Cash Book"; }
    if (Model.MENU_PARA == "JOURNAL") { ViewBag.Title = "General Ledger"; }
    if (Model.MENU_PARA == "SUBLEG") { ViewBag.Title = "Sub Ledger"; }
    Layout = "~/Views/Shared/_ReportLayout.cshtml";
}
<script src="~/Scripts/jquery.min.js" type="text/javascript"></script>
<link rel="stylesheet" href="~/Content/bootstrap-select.css" />
@Scripts.Render("~/Scripts/Multiple-Select-min.js")
@Scripts.Render("~/Scripts/bootstrap-select.js")
<script src="~/Scripts/jquery.min.js"></script>
<script>
    $(function () {
        $("#FDT").datepicker({ dateFormat: "dd/mm/yy", changeMonth: true, changeYear: true, maxDate: '@Model.maxdate' });
        $("#TDT").datepicker({ dateFormat: "dd/mm/yy", changeMonth: true, changeYear: true, maxDate: '@Model.maxdate' });
    });
</script>
@{
    string PageControllerName = "Rep_GL";
}

@using (Html.BeginForm())
{
    @Html.HiddenFor(a => Model.maxdate)
    @Html.HiddenFor(a => Model.mindate)

    <div class="form-horizontal">
        @Html.HiddenFor(s => s.DefaultAction)
        <div class="row">
            <div class="col-lg-9">
                <div class="row er">
                    <div class="col-sm-4">
                        <fieldset style="border: ridge;padding: 4px;min-width: 200px;">
                            <legend style="width: auto;margin-left:1%;margin-bottom: 6px;font-size: large;border-bottom: 0px solid;">Date Range</legend>
                            <div class="row" style="margin-top: 8px;">
                                <div class="col-sm-4">
                                    <div class="editor-label" style="margin-top: 6px;">
                                        @Html.Label("", "From Date")
                                        <b style="color:Red;">
                                            <sup>*</sup>
                                        </b>
                                    </div>
                                </div>
                                <div class="col-sm-8">
                                    <div class="editor-field">
                                        @Html.EditorFor(model => model.FDT, new { htmlAttributes = new { @class = "form-control", id = "FDT", onblur = "DocumentDateCHK(this);", @placeholder = "dd/mm/yyyy", maxlength = 10 } })
                                    </div>
                                </div>
                            </div>
                            <div class="row" style="margin-top: 8px;">
                                <div class="col-sm-4">
                                    <div class="editor-label" style="margin-top: 6px;">
                                        @Html.Label("", "To Date")
                                        <b style="color:Red;">
                                            <sup>*</sup>
                                        </b>
                                    </div>
                                </div>
                                <div class="col-sm-8">
                                    <div class="editor-field">
                                        @Html.EditorFor(model => model.TDT, new { htmlAttributes = new { @class = "form-control", id = "TDT", onblur = "DocumentDateCHK(this);", @placeholder = "dd/mm/yyyy", maxlength = 10 } })
                                    </div>
                                </div>
                            </div>
                        </fieldset>
                    </div>
                </div>

                <div class="row" style="margin-top:6px">
                    <div class="col-md-8">
                        <div class="editor-label" style="margin-top:5px">
                            @Html.Label("", "General Ledger Selection")
                        </div>
                    </div>
                    <div class="col-md-6">
                        @(new HtmlString(Model.Glnm))
                    </div>
                </div>

                @*@if (Model.MENU_PARA == "SUBLEG" || Model.MENU_PARA == "JOURNAL")
                    {*@
                <div class="row" style="margin-top:6px">
                    <div class="col-md-8">
                        <div class="editor-label" style="margin-top:5px">
                            @Html.Label("", "Party Code")
                        </div>
                    </div>
                    <div class="col-md-6">
                        @(new HtmlString(Model.Slnm))
                    </div>
                </div>
                @*}*@

                @*<div class="row" style="margin-top:6px">
                    <div class="col-md-8">
                        <div class="editor-label" style="margin-top: 2px;">
                            @Html.Label("", "Class 1 filteration")
                        </div>
                    </div>
                    <div class="col-md-6">
                        @(new HtmlString(Model.CLASS1CD))
                    </div>
                </div>

                <div class="row" style="margin-top:6px">
                    <div class="col-md-8">
                        <div class="editor-label" style="margin-top: 2px;">
                            @Html.Label("", "Class 2 filteration")
                        </div>
                    </div>
                    <div class="col-md-6">
                        @(new HtmlString(Model.CLASS2CD))
                    </div>
                </div>*@

                @if (Model.MENU_PARA == "SUBLEG" && CommVar.UserType() == "A")
                {
                    <div class="row" style="margin-top:6px">
                        <div class="col-md-8">
                            <div class="editor-label" style="margin-top:5px">
                                @Html.Label("", "Group Belongs")
                            </div>
                        </div>
                        <div class="col-md-6">
                            @(new HtmlString(Model.SLPartyGrp))
                        </div>
                    </div>
                }

                <div class="row" style="margin-top:6px">
                    <div class="col-md-8">
                        <div class="editor-label" style="margin-top:5px">
                            @Html.Label("", "Trial Group Selection")
                        </div>
                    </div>
                    <div class="col-md-6">
                        @(new HtmlString(Model.GLTBGrp))
                    </div>
                </div>

                @if (Model.MENU_PARA != "SUBLEG")
                {
                    <div class="row" style="margin-top:6px">
                        <div class="col-md-8">
                            <div class="editor-label" style="margin-top:5px">
                                @Html.Label("", "Party Grouping")
                            </div>
                        </div>
                        <div class="col-md-6">
                            @(new HtmlString(Model.SubLeg_Grp))
                        </div>
                    </div>
                }
                <div class="row" style="margin-top:6px">
                    <div class="col-md-8">
                        <div class="editor-label" style="margin-top:5px">
                            @Html.Label("", "Company+Location (Global)")
                        </div>
                    </div>
                    <div class="col-md-6">
                        @(new HtmlString(Model.CompanyLocationName))
                    </div>
                </div>
                <div class="row" style="margin-top:6px;">
                    <div class="col-md-11" style="border: 2px groove;width:auto;">
                        &nbsp; &nbsp;
                        <label class="radio-inline" style="padding-top: 2px;">
                            @Html.RadioButtonFor(g => g.TEXTBOX1, "D")  @Html.Label("Day Wise Total")
                        </label>
                        <label class="radio-inline" style="padding-top: 2px;">
                            @Html.RadioButtonFor(g => g.TEXTBOX1, "M")  @Html.Label("Month Wise Total")
                        </label>
                        <label class="radio-inline" style="padding-top: 2px;">
                            @Html.RadioButtonFor(g => g.TEXTBOX1, "Y")  @Html.Label("Year Wise Total")
                        </label>
                        <label class="radio-inline" style="padding-top: 2px;">
                            @Html.RadioButtonFor(g => g.TEXTBOX1, "G", new { @checked = "checked" })  @Html.Label("Grand Total")
                        </label>
                    </div>
                </div>
                <div class="row" style="margin-top:6px;">
                    @*<div class="col-md-6">
                        <input type="submit" formtarget="_blank" name="Command" value="Crystal" title="Show report as a Crystal a new tab" class="btn btn-default" />
                    </div>*@
                    <div class="col-md-6">
                        <input type="submit" formtarget="_blank" name="Command" value="Standard" title="Show reprot as a std in a new tab" class="btn btn-primary" />
                    </div>
                    @*<div class="col-md-6">
                        <input type="submit" formtarget="_blank" name="Command" value="Excel" title="Download Excel" class="btn btn-primary" />
                    </div>
                    <div class="col-md-6">
                        <input type="submit" formtarget="_blank" name="Command" value="CSV" title="Download CSV" class="btn btn-primary" />
                    </div>*@
                </div>
            </div>
            <div class="col-lg-3">
                <table style="border:1px solid;margin-top: 8px;float:right;">
                    <tr>
                        <td style="border:1px groove;">Print Running Balance</td>
                        <td style="border:1px groove;">@Html.CheckBoxFor(model => model.Checkbox2, new { Style = "width:18px;height:18px;" })</td>
                    </tr>
                    <tr>
                        <td style="border:1px groove;">Dr.Cr. Head</td>
                        <td style="border:1px groove;">@Html.CheckBoxFor(model => model.Checkbox3, new { Style = "width:18px;height:18px;" })</td>
                    </tr>
                    <tr>
                        <td style="border:1px groove;">Opening Bal add in Totals</td>
                        <td style="border:1px groove;">@Html.CheckBoxFor(model => model.Checkbox7, new { Style = "width:18px;height:18px;" })</td>
                    </tr>
                    @if (Model.MENU_PARA != "SUBLEG")
                    {
                        <tr>
                            <td style="border:1px groove;">Sub Ledger Detail</td>
                            <td style="border:1px groove;">@Html.CheckBoxFor(model => model.Checkbox1, new { Style = "width:18px;height:18px;" })</td>
                        </tr>
                    }
                    @*<tr>
                        <td style="border:1px groove;">Class Detail</td>
                        <td style="border:1px groove;">@Html.CheckBoxFor(model => model.Checkbox4, new { Style = "width:18px;height:18px;" })</td>
                    </tr>*@
                    <tr>
                        <td style="border:1px groove;">Cheque No. Details</td>
                        <td style="border:1px groove;">@Html.CheckBoxFor(model => model.Checkbox5, new { Style = "width:18px;height:18px;" })</td>
                    </tr>
                    <tr>
                        <td style="border:1px groove;">Bill Details</td>
                        <td style="border:1px groove;">@Html.CheckBoxFor(model => model.Checkbox6, new { Style = "width:18px;height:18px;" })</td>
                    </tr>
                    <tr>
                        <td style="border:1px groove;">Print Transaction Type</td>
                        <td style="border:1px groove;">@Html.CheckBoxFor(model => model.Checkbox8, new { Style = "width:18px;height:18px;" })</td>
                    </tr>
                    <tr>
                        <td style="border:1px groove;">Print Address</td>
                        <td style="border:1px groove;">@Html.CheckBoxFor(model => model.Checkbox10, new { Style = "width:18px;height:18px;" })</td>
                    </tr>
                    <tr>
                        <td style="border:1px groove;">Print Qnty</td>
                        <td style="border:1px groove;">@Html.CheckBoxFor(model => model.Checkbox11, new { Style = "width:18px;height:18px;" })</td>
                    </tr>
                    <tr>
                        <td style="border:1px groove;">Print Txn.Type</td>
                        <td style="border:1px groove;">@Html.CheckBoxFor(model => model.Checkbox12, new { Style = "width:18px;height:18px;" })</td>
                    </tr>
                    <tr>
                        <td style="border:1px groove;">Print Party Bill No</td>
                        <td style="border:1px groove;">@Html.CheckBoxFor(model => model.Checkbox13, new { Style = "width:18px;height:18px;" })</td>
                    </tr>
                    <tr>
                        <td style="border:1px groove;">Skip Closing Voucher</td>
                        <td style="border:1px groove;">@Html.CheckBoxFor(model => model.SkipClosingVoucher, new { Style = "width:18px;height:18px;" })</td>
                    </tr>
                    <tr>
                        <td style="border:1px groove;">Search in Only Current Locations</td>
                        <td style="border:1px groove;">@Html.CheckBoxFor(model => model.Checkbox9, new { Style = "width:18px;height:18px;" })</td>
                    </tr>
                    @*<tr>
                        <td style="border:1px groove;">Print Share Details</td>
                        <td style="border:1px groove;">@Html.CheckBoxFor(model => model.Checkbox14, new { Style = "width:18px;height:18px;" })</td>
                    </tr>*@
                </table>
            </div>
        </div>


    </div>
}
